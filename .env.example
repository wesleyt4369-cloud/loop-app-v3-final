# Copy this file to .env and fill in real values before running or deploying.

# --- Database ---
# A free Postgres database from neon.tech or supabase.com works great.
# Paste the connection string they give you here.
DATABASE_URL="postgresql://user:password@host:5432/loop"

# --- Login (protects your dashboard) ---
# Pick any password you'll use to log in to YOUR dashboard.
APP_PASSWORD="changeme"
# Any random long string — used to sign your login session. Generate one at
# https://generate-secret.vercel.app/32 or just mash the keyboard for 32+ characters.
SESSION_SECRET="replace-with-a-long-random-string"

# --- Business info ---
BUSINESS_NAME="Riverside Wellness"

# --- Twilio (real SMS sending) ---
# Create a free trial account at twilio.com, buy a phone number (~$1.15/mo),
# then copy these three values from your Twilio Console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Cron protection ---
# Any random string. Vercel Cron will send this back to prove the request
# is really coming from your scheduled job and not a stranger on the internet.
CRON_SECRET="replace-with-another-random-string"
